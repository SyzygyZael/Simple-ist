<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Simpleist" parent="android:Theme.DeviceDefault.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFF00</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/simpleistlogo</item>
        <item name="postSplashScreenTheme">@style/Theme.Simpleist</item>
    </style>

    <style name="Theme.Simpleist.WidgetConfig" parent="android:Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>